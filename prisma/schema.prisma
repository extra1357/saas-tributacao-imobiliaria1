generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  simulations Simulation[]
}

model Simulation {
  id        String   @id @default(uuid())
  userId    String
  type      String
  input     Json
  result    Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
