generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(uuid())
  name        String?
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  simulations Simulation[]
}

model Simulation {
  id        String   @id @default(uuid())
  userId    String
  type      String
  input     Json
  result    Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
