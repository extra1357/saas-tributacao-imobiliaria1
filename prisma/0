generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LegalStructure {
  PF
  PJ
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())

  organizations OrganizationUser[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     OrganizationUser[]
  portfolios PropertyPortfolio[]
}

model OrganizationUser {
  id              String   @id @default(uuid())
  userId          String
  organizationId String
  role            String

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model PropertyPortfolio {
  id              String        @id @default(uuid())
  organizationId  String
  name            String
  legalStructure  LegalStructure
  createdAt       DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  diagnostics   Diagnostic[]
}

model Diagnostic {
  id                 String   @id @default(uuid())
  portfolioId        String
  monthlyRevenue     Decimal  @db.Decimal(12,2)
  monthlyExpenses    Decimal  @db.Decimal(12,2)
  createdAt          DateTime @default(now())

  portfolio PropertyPortfolio @relation(fields: [portfolioId], references: [id])
  results   CalculationResult[]
}

model TaxEngineVersion {
  id          String   @id @default(uuid())
  name        String
  description String
  createdAt   DateTime @default(now())

  results CalculationResult[]
}

model CalculationResult {
  id                   String   @id @default(uuid())
  diagnosticId         String
  engineVersionId      String

  pfEffectiveRate      Decimal  @db.Decimal(5,2)
  pjEffectiveRate      Decimal  @db.Decimal(5,2)
  inefficiencyRate     Decimal  @db.Decimal(5,2)
  potentialAnnualSave  Decimal  @db.Decimal(14,2)
  efficiencyScore      Int

  createdAt DateTime @default(now())

  diagnostic    Diagnostic       @relation(fields: [diagnosticId], references: [id])
  engineVersion TaxEngineVersion @relation(fields: [engineVersionId], references: [id])
}
